# ─── Database ────────────────────────────────────────────────────────────────
# Используется docker-compose.prod.yml, не меняй имена хостов (postgres, redis)
POSTGRES_USER=rankpapa
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=rankpapa

# DATABASE_URL формируется автоматически в docker-compose.prod.yml
# Но если нужен override — раскомментируй:
# DATABASE_URL=postgresql://rankpapa:CHANGE_ME@postgres:5432/rankpapa

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0

# ─── Frontend ────────────────────────────────────────────────────────────────
# В продакшне фронт обращается к /api через nginx (relative), поэтому пустая строка
VITE_API_URL=

# ─── PROSOX Proxy ────────────────────────────────────────────────────────────
PROSOX_API_KEY=your_prosox_api_key
PROSOX_PACKAGE_KEY=your_prosox_package_key
PROSOX_LOGIN=your_prosox_login
PROSOX_PASSWORD=your_prosox_password
PROSOX_HOST=your_prosox_host
PROSOX_PORT=your_prosox_port

# ─── Fingerprints ────────────────────────────────────────────────────────────
FINGERPRINT_LOCALE=ru-KZ
FINGERPRINT_TIMEZONE=Asia/Almaty

# ─── Worker ──────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=8
WORKER_MAX_VISITS_PER_PROXY=10
