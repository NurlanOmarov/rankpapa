Вариант 1. Самый быстрый (рекомендую для старта)
Установка (Node.js):
Bashnpm i playwright playwright-with-fingerprints rebrowser-patches
Полный пример (один профиль = один визит):
JavaScriptconst { plugin } = require('playwright-with-fingerprints');
const { chromium } = require('rebrowser-playwright'); // или обычный playwright после патча

// 1. Берём KZ-прокси (например из твоей базы)
const proxy = {
  server: 'http://user:pass@almaty-residential.proxy-provider.com:8000',
  // или socks5
};

// 2. Получаем реальный fingerprint под Windows + Chrome (можно тегнуть под Казахстан)
const fingerprint = await plugin.fetch({
  tags: ['Microsoft Windows', 'Chrome', 'Kazakhstan'], // или без тега — рандом
  minBrowserVersion: 120
});

// 3. Применяем и запускаем
plugin.useFingerprint(fingerprint);
plugin.useProxy(proxy.server, {
  changeTimezone: true,      // автоматически подставит Asia/Almaty
  changeGeolocation: true    // широта/долгота Алматы
});

const browser = await plugin.launch({
  headless: true,           // или false для отладки
  proxy: proxy              // дублируем на всякий случай
});

const context = await browser.newContext({
  locale: 'ru-KZ',          // или 'kk-KZ'
  timezoneId: 'Asia/Almaty',
  geolocation: { latitude: 43.25, longitude: 76.95 }
});

const page = await context.newPage();

// Теперь можно запускать поведенческий скрипт
await page.goto('https://google.kz/search?q=купить+айфон+алматы');
await page.waitForTimeout(45000); // имитация dwell time + скролл
Что происходит под капотом:

FingerprintSwitcher отдаёт реальные значения Canvas, WebGL, AudioContext, fonts, hardwareConcurrency и т.д. с настоящих устройств.
useProxy + changeTimezone/geolocation автоматически синхронизирует гео.
rebrowser-patches убирает CDP-утечки (Runtime.Enable), которые ловит Google/Cloudflare.

