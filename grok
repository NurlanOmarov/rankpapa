Как технически это реализовать (MVP за 1–2 недели)
Тот же код, что ты уже пишешь для накрутки, просто меняешь логику:
JavaScript// Пример на Node.js + playwright-with-fingerprints
const { plugin } = require('playwright-with-fingerprints');

async function checkPosition(keyword, clientDomain, competitors) {
  const fingerprint = await plugin.fetch({ tags: ['Kazakhstan'] });
  plugin.useFingerprint(fingerprint);

  const browser = await plugin.launch({ headless: true });
  const context = await browser.newContext({
    locale: 'ru-KZ',
    timezoneId: 'Asia/Almaty',
    geolocation: { latitude: 43.25, longitude: 76.95 }
  });

  const page = await context.newPage();
  await page.goto(`https://www.google.kz/search?q=${encodeURIComponent(keyword)}&gl=kz&hl=ru`, { waitUntil: 'networkidle' });

  // Парсим позиции
  const results = await page.$$eval('.g', elements => 
    elements.map((el, idx) => ({
      position: idx + 1,
      url: el.querySelector('a')?.href || '',
      title: el.querySelector('h3')?.innerText || ''
    }))
  );

  const clientPos = results.findIndex(r => r.url.includes(clientDomain)) + 1;
  const competitorPos = competitors.map(comp => ({
    domain: comp,
    position: results.findIndex(r => r.url.includes(comp)) + 1
  }));

  await browser.close();
  return { keyword, clientPos, competitors: competitorPos };
}
